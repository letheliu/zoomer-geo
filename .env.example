# 数据库
DATABASE_URL="postgresql://geo:geo_secret@localhost:5432/geo?schema=public"

# 服务
PORT=4000

# LLM（内部任务用，如 query 生成）
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://open.bigapi.cn/api/paas/v4
EMBEDDING_MODEL=embedding-3
CHAT_MODEL=glm-4-flash

# 国内 AI 平台凭证（用于引用监测）
# DeepSeek
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 豆包（火山引擎）
DOUBAO_API_KEY=xxx
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-pro-4k

# 通义千问（阿里云）
QWEN_API_KEY=sk-xxx
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-turbo

# 文心一言（百度）
ERNIE_API_KEY=xxx
ERNIE_SECRET_KEY=xxx
ERNIE_MODEL=ernie-speed-128k

# 监测目标平台凭证（示例，实际存于 workspace.platformConfig）
# 各 adapter 运行时从 workspace 读取
