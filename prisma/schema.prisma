generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workspace {
  id                 String             @id @default(cuid())
  name               String
  domain             String?
  llmsTxtUrl         String?
  defaultBrandName   String
  apiKeyHash         String
  platformConfig     Json               @default("{}")
  publicationConfig  Json               @default("{}")
  status             WorkspaceStatus    @default(ACTIVE)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  events             CitationEvent[]
  queries            CitationQuery[]
  pages              ContentPage[]
  entities           KgEntity[]
  tasks              OptimizationTask[]
  schemas            SchemaRecord[]
  publicationRecords PublicationRecord[]

  @@index([status])
}

model CitationQuery {
  id             String             @id @default(cuid())
  workspaceId    String
  queryText      String
  intent         Json               @default("{}")
  intentType     String?
  cluster        String?
  mappedPageUrl  String?
  priority       Int                @default(3)
  lastRunAt      DateTime?
  source         QuerySource
  status         QueryStatus        @default(ACTIVE)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  embedding      Json?
  events         CitationEvent[]
  workspace      Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks          OptimizationTask[]

  @@index([workspaceId, status])
}

model CitationEvent {
  id               String        @id @default(cuid())
  workspaceId      String
  queryId          String
  platform         String
  brandMentioned   Boolean
  brandSourceCited Boolean      @default(false)
  rankInAnswer     Int?
  sourceRank       Int?
  citedUrls        Json          @default("[]")
  sourceCitations  Json          @default("[]")
  groundingSources Json          @default("[]")
  analysis         Json          @default("{}")
  competitors      Json          @default("[]")
  rawAnswer        String
  sovScore         Float?
  capturedAt       DateTime      @default(now())
  embedding        Json?
  query            CitationQuery @relation(fields: [queryId], references: [id], onDelete: Cascade)
  workspace        Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, platform, capturedAt])
  @@index([queryId, capturedAt])
}

model ContentPage {
  id                String             @id @default(cuid())
  workspaceId       String
  url               String
  pageType          String
  currentContent    String
  optimizedContent  String?
  publishedContent  String?
  lastPublishedAt   DateTime?
  optimizationScore Float?
  eeatScore         Float?
  citabilityScore   Float?
  status            ContentStatus      @default(DRAFT)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  workspace         Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks             OptimizationTask[]

  @@unique([workspaceId, url])
  @@index([workspaceId, status])
}

model OptimizationTask {
  id                  String         @id @default(cuid())
  workspaceId         String
  type                TaskType
  queryId             String?
  pageId              String?
  status              TaskStatus     @default(PENDING)
  beforeScore         Float?
  afterScore          Float?
  result              Json?
  reviewNote          String?
  extractionProposals Json?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  page                ContentPage?   @relation(fields: [pageId], references: [id])
  query               CitationQuery? @relation(fields: [queryId], references: [id])
  workspace           Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
}

model SchemaRecord {
  id             String       @id @default(cuid())
  workspaceId    String
  pageUrl        String
  schemaType     String
  content        Json
  llmsTxtSection String?
  status         SchemaStatus @default(ACTIVE)
  version        Int          @default(1)
  createdAt      DateTime     @default(now())
  workspace      Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, pageUrl])
  @@index([workspaceId, schemaType])
  @@index([workspaceId, status])
}

model KgEntity {
  id            String       @id @default(cuid())
  workspaceId   String
  name          String
  type          String
  properties    Json         @default("{}")
  sourceUrl     String?
  createdAt     DateTime     @default(now())
  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  relationsFrom KgRelation[] @relation("RelationFrom")
  relationsTo   KgRelation[] @relation("RelationTo")

  @@unique([workspaceId, name])
  @@index([workspaceId, type])
}

model KgRelation {
  id           String   @id @default(cuid())
  fromEntityId String
  toEntityId   String
  relationType String
  properties   Json     @default("{}")
  createdAt    DateTime @default(now())
  fromEntity   KgEntity @relation("RelationFrom", fields: [fromEntityId], references: [id], onDelete: Cascade)
  toEntity     KgEntity @relation("RelationTo", fields: [toEntityId], references: [id], onDelete: Cascade)

  @@index([fromEntityId])
  @@index([toEntityId])
}

enum WorkspaceStatus {
  ACTIVE
  SUSPENDED
}

enum QuerySource {
  GOOGLE_SUGGEST
  LLM_GENERATED
  PAA
  MANUAL
  COMPETITOR
}

enum QueryStatus {
  ACTIVE
  PAUSED
}

enum ContentStatus {
  DRAFT
  REVIEWED
  PUBLISHED
}

enum TaskType {
  OPTIMIZE_FOR_QUERY
  REWRITE_CONTENT
  GENERATE_SCHEMA
  UPDATE_KG
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  REVIEWED
  PUBLISHED
  FAILED
}

enum SchemaStatus {
  ACTIVE
  DEPRECATED
  NO_RICH_RESULTS
}

model PublicationRecord {
  id          String            @id @default(cuid())
  workspaceId String
  taskId      String?
  pageUrl     String
  targetType  String
  status      PublicationStatus @default(PENDING)
  payload     Json
  response    Json?
  error       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@index([workspaceId, pageUrl])
}

enum PublicationStatus {
  PENDING
  SUCCEEDED
  FAILED
}
